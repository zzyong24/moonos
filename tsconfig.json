{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "types": ["node"],
    "paths": {
      "@moonos/protocols": ["./src/protocols/index.ts"],
      "@moonos/protocols/*": ["./src/protocols/*"],
      "@moonos/core": ["./src/core/index.ts"],
      "@moonos/core/*": ["./src/core/*"],
      "@moonos/storage": ["./src/storage/index.ts"],
      "@moonos/storage/*": ["./src/storage/*"]
    }
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules", "**/*.test.ts"]
}
