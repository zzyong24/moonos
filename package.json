{
  "name": "moonos",
  "version": "0.3.0",
  "description": "MoonOS — AI Sovereignty Control Plane. CLI-first protocol engine for portable AI assets.",
  "type": "module",
  "bin": {
    "moonos": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/protocols/index.d.ts",
      "import": "./dist/protocols/index.js"
    },
    "./protocols": {
      "types": "./dist/protocols/index.d.ts",
      "import": "./dist/protocols/index.js"
    }
  },
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "moonos": "tsx src/cli/index.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "ai",
    "sovereignty",
    "memory",
    "protocol",
    "cli",
    "moonos"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "commander": "^13.1.0",
    "nanoid": "^5.1.5",
    "zod": "^3.24.4",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.15.2",
    "tsup": "^8.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
